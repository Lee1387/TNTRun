{
  "name": "lee1387/tntrun",
  "require": {
    "pocketmine/pocketmine-mp": "^5.41"
  },
  "require-dev": {
    "friendsofphp/php-cs-fixer": "^3.0",
    "phpstan/extension-installer": "^1.4",
    "phpstan/phpstan": "^2.1",
    "phpstan/phpstan-phpunit": "^2.0",
    "phpstan/phpstan-strict-rules": "^2.0"
  },
  "autoload": {
    "psr-4": {
      "": [
        "src"
      ]
    }
  },
  "scripts": {
    "analyse": "phpstan analyse -c phpstan.neon.dist --no-progress",
    "format": "php-cs-fixer fix --config=.php-cs-fixer.dist.php --allow-risky=no",
    "format:check": "php-cs-fixer fix --config=.php-cs-fixer.dist.php --allow-risky=no --dry-run --diff"
  },
  "config": {
    "platform": {
      "php": "8.2.0"
    },
    "allow-plugins": {
      "phpstan/extension-installer": true
    }
  }
}
