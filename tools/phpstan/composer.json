{
  "name": "lee1387/tntrun-phpstan",
  "require": {
    "pocketmine/pocketmine-mp": "5.41.1"
  },
  "require-dev": {
    "phpstan/extension-installer": "^1.4",
    "phpstan/phpstan": "^2.1",
    "phpstan/phpstan-phpunit": "^2.0",
    "phpstan/phpstan-strict-rules": "^2.0"
  },
  "autoload": {
    "psr-4": {
      "lee1387\\tntrun\\": "../../src/lee1387/tntrun/"
    }
  },
  "scripts": {
    "analyse": "phpstan analyze -c phpstan.neon.dist --no-progress"
  },
  "config": {
    "platform": {
      "php": "8.2.0"
    },
    "allow-plugins": {
      "phpstan/extension-installer": true
    }
  }
}
